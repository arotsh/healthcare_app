# Workspace host — protocol stripped, no trailing slash
DATABRICKS_HOST=dbc-822c98e3-262c.cloud.databricks.com

# Personal Access Token: User Settings → Developer → Access tokens → Generate new
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# SQL Warehouse HTTP path: SQL Warehouses → pick one → Connection Details → "HTTP Path"
# Looks like: /sql/1.0/warehouses/abc123def456
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/REPLACE_ME

# Fully qualified table name (catalog.schema.table)
DATABRICKS_TABLE=main.medimap.hospitals

# Databricks Foundation Model (used to summarize agent results conversationally)
DATABRICKS_AGENT_URL=https://dbc-822c98e3-262c.cloud.databricks.com/serving-endpoints/databricks-meta-llama-3-3-70b-instruct/invocations
DATABRICKS_AGENT_MODEL=databricks-meta-llama-3-3-70b-instruct

# Healthcare agent: scored facility table (the one your notebook reads via spark.table)
DATABRICKS_AGENT_TABLE=workspace.default.facility_signals

# Groq API key for query parsing (llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_REPLACE_ME

# Mosaic AI Vector Search (semantic retrieval over facility profiles)
DATABRICKS_VS_ENDPOINT=medimap_vs
DATABRICKS_VS_INDEX=workspace.default.clean_facilities_vs_index

# MLflow 3 tracing (per-request runs with stage latencies + token cost)
MLFLOW_EXPERIMENT_PATH=/Users/arayikdev@gmail.com/medimap-traces
# Optional: override Llama 3.3 70B pay-per-token rates ($/1M tokens)
# MLFLOW_LLAMA_INPUT_USD_PER_MTOK=0.5
# MLFLOW_LLAMA_OUTPUT_USD_PER_MTOK=1.5

# Genie (text-to-SQL agent for analytical questions)
DATABRICKS_GENIE_SPACE_ID=01f140d6f5be18759b1461d0872c5779

# Optional — once medimap_agent_bricks.py has deployed an endpoint, set its
# name here to route SEARCH traffic through it instead of orchestrating
# parse → vector search → SQL → summarize locally. Falls back to local on error.
# DATABRICKS_BRICKS_AGENT_ENDPOINT=medimap-agent

# Server
# Offline / demo mode. Set both to 1 to run without any Databricks compute —
# uses bundled backend/data/facilities_demo.js + Groq for LLM calls.
LOCAL_MODE=0
USE_GROQ=0

# Optional generic LLM (OpenAI-compatible). Overrides USE_GROQ + Databricks
# when set. Use this if you've hit Groq's daily quota and want to plug in
# OpenAI / OpenRouter / Together / your own vLLM.
# LLM_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_API_KEY=sk-or-...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

PORT=3001
CORS_ORIGIN=http://localhost:5173
